# External MySQL. Create the database first and URL-encode special characters in the password.
APP_DATABASE_URL=mysql+asyncmy://materials_user:change-me@host.docker.internal:3306/materials_manager?charset=utf8mb4
APP_JWT_SECRET=replace-with-at-least-32-random-characters
APP_ACCESS_TOKEN_MINUTES=480

# One CCR repository with separate frontend/backend tags.
CCR_IMAGE=ccr.ccs.tencentyun.com/yangrucheng/materials-manager
BACKEND_IMAGE_TAG=backend
FRONTEND_IMAGE_TAG=frontend

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000
