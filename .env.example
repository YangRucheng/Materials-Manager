# External MySQL on 1panel-network. Replace "mysql" with its container name.
# Create the database first and URL-encode special characters in the password.
APP_DATABASE_URL=mysql+asyncmy://materials_user:change-me@mysql:3306/materials_manager?charset=utf8mb4
APP_JWT_SECRET=replace-with-at-least-32-random-characters
APP_ACCESS_TOKEN_MINUTES=480
APP_LOG_BACKUP_COUNT=90

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000
