    {"column": "J", "header": "是否保质期管理物料", "required": "必填", "instruction": "是或否", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "K", "header": "保质期（天数）", "required": "必填", "instruction": "如果是保质期管理物料则必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "L", "header": "资产类别", "required": "必填", "instruction": "可咨询资产管理员确认。", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "M", "header": "新增原因说明", "required": "必填", "instruction": "说明用途、使用频率、有无替代物料及调拨可能性。", "field": "application_reason", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "N", "header": "申请部门", "required": "必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "O", "header": "申请人", "required": "必填", "field": "actual_demand_person", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "P", "header": "拟停止采购的物料编码", "required": "必填", "instruction": "一换一物料与拟新增物料应同属一个大类。", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "Q", "header": "拟停止采购的物料名称", "required": "必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "R", "header": "拟停止采购的物料型号", "required": "必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "S", "header": "拟停止采购的物料单位", "required": "必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "T", "header": "物料编码", "required": "必填", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "U", "header": "物料名称", "required": "必填", "instruction": "物料名称", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "V", "header": "规格型号", "required": "必填", "instruction": "物料的规格型号", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "W", "header": "适配的设备", "required": "生产设备备件(J类)必填", "instruction": "适配的设备/车型", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "X", "header": "适配设备的规格型号", "required": "生产设备备件(J类)必填", "instruction": "适配设备/车辆的规格型号", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "Y", "header": "适配设备的厂家", "required": "生产设备备件(J类)必填", "instruction": "适配设备/车辆的厂家", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "Z", "header": "单位", "instruction": "单位", "header_style": "header", "required_style": "header", "data_style": "data"},
    {"column": "AA", "header": "资产类别", "header_style": "header", "required_style": "header", "data_style": "data"}
  ]
