    {"column": "D", "header": "物料名称", "required": "必填", "instruction": "按照物料编码规范填写物资名称，规格型号等不可填入；每行物资对应一个规格型号。", "field": "name", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "E", "header": "物料的规格型号", "required": "必填", "instruction": "型号信息之间用右斜杠“\\”分隔；乘号用×，直径用Φ；字符控制在150字符以内。", "field": "model_spec", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "F", "header": "适配的设备", "required": "生产设备备件(J类)必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "G", "header": "适配设备的型号", "required": "生产设备备件(J类)必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
    {"column": "H", "header": "适配设备的厂家", "required": "生产设备备件(J类)必填", "header_style": "applicant_header", "required_style": "required", "data_style": "applicant_data"},
